DATABASE_URL=postgresql://saifer:change-me@postgres:5432/postresWaroLabs
REDIS_URL=redis://redis:6379/0
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_COLLECTOR_PROTOCOL=http/protobuf
PHOENIX_API_KEY=
OTEL_SERVICE_NAME=waro-ai-agents
OTEL_ENABLED=true
OTEL_EXPORT_TIMEOUT_SECONDS=5
ENVIRONMENT=development
AGENT_API_PORT=8100
WARO_RUNTIME_NETWORK=waro-network
INTERNAL_SIGNATURE_SECRET=
WARO_CLI_BINARY=/usr/local/bin/waro
WARO_API_URL=
WARO_API_KEY=
TOOL_TIMEOUT_SECONDS=30
TOOL_RESULT_MAX_BYTES=200000
LLM_PROVIDER=disabled
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2
KIMI_ROUTER_MODEL=
KIMI_PLANNER_MODEL=
KIMI_ANALYSIS_MODEL=
KIMI_COMPOSER_MODEL=
LLM_TIMEOUT_SECONDS=30

# --- Kali agent (CLI-driven catalog + ReAct) ---
# legacy | shadow | react — see services/agent-api/.env.example
AGENT_MODE=legacy
TOOL_CATALOG_SOURCE=cli
TOOL_CATALOG_REFRESH_SECONDS=300
AGENT_MAX_STEPS_SIMPLE=6
AGENT_MAX_STEPS_COMPLEX=10
AGENT_CONVERSATION_MESSAGE_LIMIT=8

# Phoenix self-hosted UI/auth. Required only when the observability profile is enabled.
PHOENIX_ENABLE_AUTH=true
PHOENIX_SECRET=
PHOENIX_ADMIN_SECRET=
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=
PHOENIX_ENABLE_STRONG_PASSWORD_POLICY=true
PHOENIX_USE_SECURE_COOKIES=true
PHOENIX_ROOT_URL=https://phoenix.warocol.com
PHOENIX_CSRF_TRUSTED_ORIGINS=https://phoenix.warocol.com
PHOENIX_SQL_DATABASE_URL=postgresql://saifer:change-me@postgres:5432/postresWaroLabs

# Deployment notes:
# - Copy this file to .env on the server and fill real values there.
# - infra/docker-compose.server.yml reads ../.env. Do not commit that file.
# - INTERNAL_SIGNATURE_SECRET must match api_warocol.com's proxy secret.
# - WARO_API_URL and WARO_API_KEY are runtime secrets used by the waro CLI.
# - DATABASE_URL should point at the shared Postgres service/network.
# - The server compose owns Redis by default with REDIS_URL=redis://redis:6379/0.
# - WARO_RUNTIME_NETWORK should match api_warocol.com's shared Docker network
#   so api_warocol can call http://agent-api:8100 by container DNS.
# - Phoenix/OTEL are optional observability. If Phoenix auth is enabled, create
#   a Phoenix System API Key and set PHOENIX_API_KEY so agent-api can export
#   authenticated OTLP traces.
