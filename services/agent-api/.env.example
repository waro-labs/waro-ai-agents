# Copy to .env and fill real values. Do not commit .env.
# cp .env.example .env

# --- Core ---
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8100
DATABASE_URL=postgresql://saifer:change-me@localhost:5432/postresWaroLabs
REDIS_URL=redis://localhost:6379/0
INTERNAL_SIGNATURE_SECRET=

# --- WARO CLI / tool gateway ---
WARO_CLI_BINARY=waro
WARO_API_URL=
WARO_API_KEY=
TOOL_TIMEOUT_SECONDS=30
TOOL_RESULT_MAX_BYTES=200000

# --- LLM (Kimi / Moonshot) ---
# disabled = local deterministic fallback for tests/dev
# kimi = conversational agent planning, analysis and composition
LLM_PROVIDER=disabled
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k
# Optional per-role models (fallback to KIMI_MODEL when empty)
KIMI_ROUTER_MODEL=
KIMI_PLANNER_MODEL=
KIMI_ANALYSIS_MODEL=
KIMI_COMPOSER_MODEL=
LLM_TIMEOUT_SECONDS=30

# --- Kali agent (CLI-driven catalog + conversational loop) ---
AGENT_MODE=react

# cli    = load tools from `waro schema` (waro.agent.v2), refresh on TTL
# static = embedded TOOL_SPECS fallback only
TOOL_CATALOG_SOURCE=cli
TOOL_CATALOG_REFRESH_SECONDS=300
AGENT_MAX_STEPS_SIMPLE=6
AGENT_MAX_STEPS_COMPLEX=10
AGENT_CONVERSATION_MESSAGE_LIMIT=8

# --- OpenTelemetry / Phoenix (optional) ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=waro-ai-agents
OTEL_EXPORT_TIMEOUT_SECONDS=5
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
PHOENIX_COLLECTOR_PROTOCOL=grpc
PHOENIX_API_KEY=

# --- Staging example ---
# AGENT_MODE=react
# LLM_PROVIDER=kimi
# KIMI_API_KEY=your-key
# KIMI_ROUTER_MODEL=moonshot-v1-8k
# KIMI_PLANNER_MODEL=moonshot-v1-8k
# KIMI_ANALYSIS_MODEL=moonshot-v1-32k
# KIMI_COMPOSER_MODEL=moonshot-v1-8k
